<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Калькулятор ППС/NGT"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/labelCalculationType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Выберите тип расчета:"
            android:textSize="16sp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/titleText"
            app:layout_constraintStart_toStartOf="parent" />

        <Spinner
            android:id="@+id/calculationTypeSpinner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@+id/labelCalculationType"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/labelOgpOvp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Выберите тип:"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/calculationTypeSpinner"
            app:layout_constraintStart_toStartOf="parent" />

        <Spinner
            android:id="@+id/ogpOvpSpinner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/labelOgpOvp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/labelPpsVolume"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Объем ППС (м³):"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ogpOvpSpinner"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/ppsVolume"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="Введите объем"
            android:padding="12dp"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/labelPpsVolume"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/labelNgtVolume"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Объем NGT (м³):"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ppsVolume"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/ngtVolume"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="Введите объем"
            android:padding="12dp"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/labelNgtVolume"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />


        <TextView
            android:id="@+id/labelPpsToPrepare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Сколько приготовить ППС (м³):"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ngtVolume"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/ppsToPrepare"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="Введите объем"
            android:padding="12dp"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/labelPpsToPrepare"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/labelNgtToPrepare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Сколько приготовить NGT (м³):"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ppsToPrepare"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/ngtToPrepare"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="Введите объем"
            android:padding="12dp"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/labelNgtToPrepare"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/calculateBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Рассчитать"
            android:paddingTop="12dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@+id/ngtToPrepare"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />


        <TextView
            android:id="@+id/ppsResultsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ППС Раствор №1:"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/calculateBtn"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/ppsNaNO2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:padding="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ppsResultsTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/ppsPAA"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:padding="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ppsNaNO2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/ppsWater"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:padding="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ppsPAA"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/ppsResultsTitle2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ППС Раствор №2:"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ppsWater"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/ppsNH4NO3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:padding="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ppsResultsTitle2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/ppsAcetate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:padding="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ppsNH4NO3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/ppsUK"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:padding="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ppsAcetate"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/ppsWater2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:padding="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ppsUK"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/ngtResultsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NGT-Chem-3:"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ppsWater2"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/ngtChem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:padding="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ngtResultsTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/ngtChrysotile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:padding="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ngtChem"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/ngtFiber"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:padding="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ngtChrysotile"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/ngtWater"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:padding="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ngtFiber"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>